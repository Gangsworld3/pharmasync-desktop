{
  "name": "pharmasync-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop-first pharmacy and business management platform foundation for low-connectivity markets.",
  "author": "PharmaSync",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron:dev": "electron electron/main.js",
    "dist": "electron-builder --win nsis portable",
    "db:generate": "prisma generate",
    "db:push": "node src/db/init-sqlite.js",
    "db:seed": "node src/db/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@flydotio/litestream": "^1.0.1",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "7.6.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.2.3",
    "prisma": "7.6.0"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.pharmasync.desktop",
    "productName": "PharmaSync Desktop",
    "files": [
      "desktop/**/*",
      "src/**/*",
      "prisma/**/*",
      "backend/**/*",
      "electron/**/*",
      "server.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dockerfile": {
    "litestream": true
  }
}
