{
  "name": "pharmasync-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop-first pharmacy and business management platform foundation for low-connectivity markets.",
  "author": "PharmaSync",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron:dev": "electron electron/main.js",
    "react:dev": "vite --config desktop/react/vite.config.js",
    "react:build": "vite build --config desktop/react/vite.config.js",
    "react:preview": "vite preview --config desktop/react/vite.config.js",
    "dist": "electron-builder --win nsis portable",
    "db:generate": "prisma generate",
    "db:push": "node src/db/init-sqlite.js",
    "db:seed": "node src/db/seed.js",
    "test:desktop-sync": "node scripts/run-desktop-suite.js sync",
    "test:architecture": "node scripts/architecture-guard.js && node scripts/run-desktop-suite.js architecture",
    "test:architecture:guard": "node scripts/architecture-guard.js",
    "test:desktop-chaos": "node scripts/run-desktop-suite.js chaos",
    "test:desktop-chaos-matrix": "node scripts/run-desktop-suite.js matrix",
    "simulate:sync": "node desktop-tests/sync-simulation-runner.js",
    "simulate:sync:high-failure": "node desktop-tests/sync-simulation-runner.js --profile high-failure",
    "simulate:sync:high-conflict": "node desktop-tests/sync-simulation-runner.js --profile high-conflict",
    "simulate:sync:latency": "node desktop-tests/sync-simulation-runner.js --profile latency",
    "simulate:pharmacy-day": "node desktop-tests/pharmacy-day-simulation.js",
    "analyze:sync-logs": "node scripts/analyze-sync-logs.js",
    "check:render-config": "node scripts/check-render-config.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "7.6.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.2.3",
    "prisma": "7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.3"
  },
  "build": {
    "appId": "com.pharmasync.desktop",
    "productName": "PharmaSync Desktop",
    "files": [
      "desktop/**/*",
      "src/**/*",
      "prisma/**/*",
      "backend/**/*",
      "electron/**/*",
      "server.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
